  <diagram id="S8rIBx3uFrdYcW14SCHz" name="sequence login">
    <mxGraphModel dx="1935" dy="1043" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n  autonumber\n  actor Aktor as Pengguna\n  participant UI as LoginPage&lt;br&gt;(UI View)\n  participant Prov as AuthProvider&lt;br&gt;(Controller)\n  participant Serv as AuthService&lt;br&gt;(Service)\n  participant FB as Firebase Auth&lt;br&gt;&amp; Firestore\n\n  Aktor-&gt;&gt;UI: Input Email &amp; Password,&lt;br&gt;klik tombol \&quot;Login\&quot;\n  activate UI\n  UI-&gt;&gt;Prov: login(email, password)\n  activate Prov\n  Prov-&gt;&gt;Serv: signInWithEmailAndPassword(email, password)\n  activate Serv\n  Serv-&gt;&gt;FB: signInWithEmailAndPassword()\n  activate FB\n\n  alt Kredensial Tidak Valid\n    FB--&gt;&gt;Serv: Throw FirebaseAuthException\n    Serv--&gt;&gt;Prov: Return Error Message\n    Prov--&gt;&gt;UI: Tampilkan error\n    UI--&gt;&gt;Aktor: Tampilkan pesan \&quot;Email atau Password Salah\&quot;\n  else Kredensial Valid\n    FB--&gt;&gt;Serv: Return UserCredential (uid)\n    Serv-&gt;&gt;FB: collection(&#39;users&#39;).doc(uid).get()\n    FB--&gt;&gt;Serv: Return User Document (role: Owner/Admin)\n    deactivate FB\n    Serv--&gt;&gt;Prov: Return UserModel(isOwner, isAdmin)\n    deactivate Serv\n    Prov-&gt;&gt;Prov: notifyListeners()\n    Prov--&gt;&gt;UI: Login Sukses\n    deactivate Prov\n    UI--&gt;&gt;Aktor: Alihkan ke Halaman Utama Dasbor\n    deactivate UI\n  end&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="QxZE_guNTV9DY0aQOMMb-1">
