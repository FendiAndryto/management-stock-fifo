  <diagram id="QyLE3LY8I8wGNB9IQiIq" name="sequence logout">
    <mxGraphModel dx="1407" dy="758" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    autonumber\n    actor Aktor as 🧑‍💼 Pengguna\n    participant UI as 📱 ProfileWidget\n    participant Prov as ⚙️ AuthProvider\n    participant Serv as 🔧 AuthService\n    participant FB as ☁️ Firebase Auth\n\n    Aktor -&gt;&gt; UI: Klik Tombol \&quot;Keluar / Logout\&quot;\n    UI --&gt;&gt; Aktor: Tampilkan Dialog Konfirmasi \&quot;Apakah Anda Yakin?\&quot;\n    Aktor -&gt;&gt; UI: Klik \&quot;Ya, Keluar\&quot;\n    UI -&gt;&gt; Prov: logout()\n    Prov -&gt;&gt; Serv: signOut()\n    Serv -&gt;&gt; FB: FirebaseAuth.instance.signOut()\n    FB --&gt;&gt; Serv: Session Terminated\n    Serv --&gt;&gt; Prov: Logout Success\n    Prov -&gt;&gt; Prov: notifyListeners() (Clear User Data)\n    Prov --&gt;&gt; UI: Sesi Berakhir\n    UI --&gt;&gt; Aktor: Alihkan Kembali ke Halaman Login&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="4ryPOtgm65fCqVfm3TH0-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
