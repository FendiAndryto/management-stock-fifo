        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n  namespace Users_Authentication {\n    class UserModel {\n      +String uid\n      +String email\n      +String nama\n      +String role\n      +bool isOwner\n      +bool isAdmin\n    }\n    class Authentication {\n      &lt;&lt;Service&gt;&gt;\n      +UserModel? currentUser\n      +bool login(email, pass)\n      +void logout()\n      +bool registerAdmin(...)\n    }\n  }\n\n  namespace Products_FIFO_Batches {\n    class ProductModel {\n      +String id\n      +String namaBarang\n      +String kategori\n      +int stokTotal\n      +int stokMinimum\n      +double hargaJual\n      +bool isLowStock\n    }\n    class StockBatchModel {\n      +String batchId\n      +String productId\n      +int stokAwal\n      +int stokTersisa\n      +double hargaBeli\n      +DateTime tanggalMasuk\n    }\n  }\n\n  namespace Transactions {\n    class TransactionModel {\n      +String txId\n      +String tipe\n      +String productId\n      +String namaBarang\n      +int jumlah\n      +DateTime tanggal\n      +String userId\n      +String namaUser\n      +String keterangan\n    }\n  }\n\n  namespace Inventory_Management {\n    class InventoryManagement {\n      &lt;&lt;Service&gt;&gt;\n      +List~ProductModel~ products\n      +double totalValuation\n      +bool addStockIn(...)\n      +bool addStockOutFIFO(...)\n      +void exportReports(...)\n    }\n  }\n\n  Authentication \&quot;1\&quot; o-- \&quot;0..1\&quot; UserModel : mengelola\n  InventoryManagement \&quot;1\&quot; o-- \&quot;0..*\&quot; ProductModel : mengelola\n  InventoryManagement \&quot;1\&quot; o-- \&quot;0..*\&quot; TransactionModel : mengelola\n  ProductModel \&quot;1\&quot; *-- \&quot;0..*\&quot; StockBatchModel : \&quot;memiliki lot FIFO\&quot;\n  ProductModel \&quot;1\&quot; &lt;-- \&quot;0..*\&quot; TransactionModel : \&quot;merekam mutasi\&quot;\n  UserModel \&quot;1\&quot; &lt;-- \&quot;0..*\&quot; TransactionModel : \&quot;dilakukan oleh\&quot;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="T_Cv-RzrPKzvyeGT5Vub-126">
