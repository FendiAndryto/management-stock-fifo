        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    autonumber\n    actor Owner as 👑 Owner\n    participant UI as 📱 ItemFormDialog\n    participant Prov as ⚙️ InventoryProvider\n    participant Serv as 🔧 FirestoreService\n    participant FB as ☁️ Cloud Firestore\n\n    Owner -&gt;&gt; UI: Mengisi Nama Barang, Satuan, Harga Jual, Batas Min -&gt; Klik \&quot;Simpan\&quot;\n    UI -&gt;&gt; UI: Validasi Form Lokal (Form Not Empty)\n\n    alt Form Kosong / Tidak Valid\n        UI --&gt;&gt; Owner: Tampilkan Peringatan Validasi Merah\n    else Form Valid\n        UI -&gt;&gt; Prov: addItem(itemModel) / updateItem(itemModel)\n        Prov -&gt;&gt; Serv: saveItemToFirestore(itemModel)\n\n        alt Aksi Tambah Barang Baru\n            Serv -&gt;&gt; FB: collection(&#39;items&#39;).add(itemData)\n            FB --&gt;&gt; Serv: Return DocumentReference ID\n        else Aksi Edit / Hapus Barang\n            Serv -&gt;&gt; FB: collection(&#39;items&#39;).doc(id).update() / delete()\n            FB --&gt;&gt; Serv: Operation Success\n        end\n\n        Serv --&gt;&gt; Prov: Konfirmasi Berhasil\n        Prov -&gt;&gt; Prov: notifyListeners() (Refresh Stream)\n        Prov --&gt;&gt; UI: State Terperbarui\n        UI --&gt;&gt; Owner: Tutup Dialog &amp; Tampilkan Katalog Terbaru\n    end&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="QNB9iKpWpLl74Dc2_wT2-51">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
