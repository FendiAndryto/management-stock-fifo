  <diagram id="ODs1hanfJvliMbYJA4tg" name="sequence barang masuk">
    <mxGraphModel dx="1935" dy="1043" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    autonumber\n    actor Aktor as 🧑‍💼 Pengguna (Owner/Admin)\n    participant UI as 📱 StockInPage\n    participant Prov as ⚙️ InventoryProvider\n    participant Serv as 🔧 FirestoreService\n    participant FB as ☁️ Cloud Firestore\n\n    Aktor -&gt;&gt; UI: Pilih Barang, Input Jumlah Masuk, Harga Beli, Tanggal -&gt; Klik \&quot;Simpan\&quot;\n    UI -&gt;&gt; Prov: addStockIn(itemId, qty, buyPrice, date, notes)\n    Prov -&gt;&gt; Serv: recordStockInFIFO(transactionData)\n    Note over Serv,FB: Mulai Firebase Write Batch Transaction\n    Serv -&gt;&gt; FB: 1. collection(&#39;transactions&#39;).add(stockInDoc)\n    Serv -&gt;&gt; FB: 2. collection(&#39;items&#39;).doc(id).collection(&#39;batches&#39;).add(newBatchDoc)\n    Note right of FB: Batch baru berisi: initialQty, remainingQty, buyPrice, date\n    Serv -&gt;&gt; FB: 3. collection(&#39;items&#39;).doc(id).update(totalStock += qty)\n    FB --&gt;&gt; Serv: Batch Commit Sukses\n    Serv --&gt;&gt; Prov: Konfirmasi Transaksi Masuk Berhasil\n    Prov -&gt;&gt; Prov: notifyListeners()\n    Prov --&gt;&gt; UI: Update UI State\n    UI --&gt;&gt; Aktor: Tampilkan Notifikasi \&quot;Barang Masuk Berhasil Dicatat\&quot;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="m2_Oe6iwBBys7_PNqRUf-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="(Owner/Admin)" mermaidId="n:Aktor" mermaidBaseStyle="html=1;shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=1;dropTarget=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;newEdgeStyle={&quot;edgeStyle&quot;:&quot;elbowEdgeStyle&quot;,&quot;elbow&quot;:&quot;vertical&quot;,&quot;curved&quot;:0,&quot;rounded&quot;:0};lifelineDashed=0;strokeWidth=2;rounded=1;absoluteArcSize=1;arcSize=6;lifelineColor=light-dark(#9370DB,#cccccc);participant=seqActorStick;verticalAlign=bottom;align=center;spacingBottom=4;size=90;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="🧑‍💼 Pengguna (Owner/Admin)" id="m2_Oe6iwBBys7_PNqRUf-2">
