  <diagram id="MGOQZZlV8aQAGDW7Xpl7" name="sequence ekspor laporan transaksi">
    <mxGraphModel dx="2211" dy="1191" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    autonumber\n    actor Owner as 👑 Owner\n    participant UI as 📱 ExportReportDialog\n    participant Prov as ⚙️ InventoryProvider\n    participant Serv as 🔧 ExportService\n    participant OS as 🖨️ Printing Engine (OS)\n\n    Owner -&gt;&gt; UI: Klik \&quot;Ekspor Laporan\&quot; -&gt; Pilih Laporan Stok (PDF) -&gt; Klik Export\n    UI -&gt;&gt; Prov: exportStockReport(format: PDF)\n    Prov -&gt;&gt; Serv: generateStockReportPdf(items, batches, companyLogo)\n\n    alt Role Pengguna == Admin (Akses Ditolak)\n        Serv --&gt;&gt; Prov: Throw PermissionDeniedException\n        Prov --&gt;&gt; UI: Tampilkan pesan error\n        UI --&gt;&gt; Owner: Tampilkan peringatan \&quot;Ekspor Laporan Khusus Owner\&quot;\n    else Role Pengguna == Owner (Akses Diterima)\n        Serv -&gt;&gt; Serv: 1. Muat Aset Gambar logo.png dari bundle aplikasi\n        Serv -&gt;&gt; Serv: 2. Susun Dokumen PDF (Kop Surat CV Maju Bersama, Tabel Rupiah, Blok Tanda Tangan)\n        Serv -&gt;&gt; OS: Printing.sharePdf(bytes: pdfBytes, filename: &#39;Laporan_Stok.pdf&#39;)\n        OS --&gt;&gt; Owner: Tampilkan Dialog Native OS (Kirim WhatsApp, Email, atau Bluetooth Print)\n    end&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="EVnBMh_duLu9ZYPA972d-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
